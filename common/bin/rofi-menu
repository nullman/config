#!/usr/bin/env bash
#===============================================================================
# rofi-menu
#
# Present a menu of rofi menus.
#
# Symbols: пғү вҳ° пҒ» | пғ„ пғ… пғҶ | вңӮ вҺҳ у°„¶ оӯү пғӘ у°…Ң у°…Қ у°Ёё уұүҘ уұүҰ уұү§ уұүЁ уұү« уұү¬ пғҶ | оҷІ
# Symbols: у°Қ№ оҡғ оһ• оӘ… | оҳ© | п„Ұ пҗҳ пҗҷ уұҮ  пҠҮ | у°Ҷ§ | пғ¬ | пҺө пҖҒ у°қҡ | у°ӣҮ | у°ғғ у°ғҖ | у°Ҝ« у°ҲҚ оӯҪ п„ӯ у°Җ¬ о©ў к“ҙ | вҢӮ | у°Ҫ’
#
# Required utilities:
#   cool-retro-term
#   curl
#   dosbox
#   ffplay
#   rofi
#   trans
#   unipicker
#   vncviewer
#   xdg-utils
#
# Author: Kyle W T Sherman <kylewsherman@gmail.com>
#===============================================================================

set -eu #o pipefail

# display usage information
_usage() {
    cat <<EOF
Usage: $(basename "$0") [MENU]
Present a menu of rofi menus.
MENU:
  NONE                Menu of Selections
  terminal            Terminal
  acronyms-computing  Acronyms: Computing
  bookmarks           Bookmarks
  bookmarks-keyword   Bookmarks: Keyword
  contacts            Contacts
  crt                 Cool Retro Term
  dosbox              DOSBox Emulator
  emoji               Emoji Search
  footnotes           Footnote Symbols
  git                 Synchronize Repositories
  home                Home Page Bookmarks
  paste               Paste Strings
  password            Generate Password
  qemu                QEMU Emulator
  rsync               Synchronize Files
  sounds              Play Sounds
  spell               Spell Check & Definition
  ssh                 SSH into Systems
  typer               Type Strings
  unicode             Unicode Search
  vnc                 VNC into Systems
EOF
}

# handle no arguments given
if [ $# -lt 1 ] ; then
    menus=(
        "оҡғ	Terminal"
        "у°Ҝ«	Acronyms: Computing"
        "у°ғғ	Bookmarks"
        "у°ғғ	Bookmarks: Keyword"
        "у°ҲҚ	Contacts"
        "у°Қ№	CRT"
        "оҳ©	DOSBox"
        "рҹҳғ	Emoji"
        "у°Ҫ’	Footnotes"
        "п„Ұ	Git"
        "вҢӮ	Home"
        "пғӘ	Paste"
        "оҷІ	Password"
        "у°Ҷ§	Qemu"
        "пғ¬	Rsync"
        "у°қҡ	Sounds"
        "о©ў	Spell"
        "оҡғ	SSH"
        "оӯҪ	Typer"
        "U	Unicode"
        "у°ӣҮ	VNC"
    )
    menu=$(printf '%s\n' "${menus[@]}" | rofi -dmenu -i -p 'пғү	Menu')
else
    menu=$1
fi

# handle menu
menu=$(printf '%s' "${menu}" | sed 's/^.*\t//' | tr '[:upper:]' '[:lower:]' | tr -d ':' | tr ' ' '-')
#echo "${menu}"
case "${menu}" in
    terminal)
        (alacritty &)
        ;;

    acronyms-computing)
        (
            curl --silent "https://en.wikipedia.org/wiki/List_of_computing_and_IT_abbreviations" |
                grep "^<li>" |
                grep "/wiki/" |
                sed 's%^<li><a[^>]\+>\(.\+\)</a>\(.\+\)</li>%\1: \2% ;
                    s%вҖ”%%g ; s%</ul>%% ; s%</\?b>%%g ; s%\&amp;%\&% ;
                    s%<sup .*</sup>%%g ; s%</div>%%g ; s%</a>$%% ;
                    s%<a [^>]*>%% ; s%</a>%: %' |
                grep -v '^<li>' | rofi -dmenu -i -p 'у°Ҝ«	Acronyms: Computing' &
        )
        ;;

    bookmarks)
        # display bookmarks
        if [ $# -lt 2 ] ; then
            sel=$(cat "${HOME}/Documents/bookmarks.txt" | rofi -font 'System San Francisco Display 12' -dmenu -i -p 'у°ғғ	Bookmarks')
        else
            sel=$2
        fi

        # open bookmark
        if [ -n "${sel}" ] ; then
            url=$(printf '%s' "${sel}" | sed 's/^.* \([^ ]*$\)/\1/')
            (xdg-open "${url}" &)
        fi
        ;;

    bookmarks-keyword)
        # display bookmarks having keywords
        if [ $# -lt 2 ] ; then
            sel=$(sed -n 's/^.* {\(.*\)}: /\1 -> /p' "${HOME}/Documents/bookmarks.txt" | sort | rofi -font 'System San Francisco Display 12' -matching prefix -dmenu -i -p 'у°ғғ	Bookmarks: Keyword')
        else
            sel=$2
        fi

        # open bookmark
        if [ -n "${sel}" ] ; then
            url=$(printf '%s' "${sel}" | sed 's/^.* \([^ ]*$\)/\1/')
            (xdg-open "${url}" &)
        fi
        ;;

    contacts)
        # display contacts
        if [ $# -lt 2 ] ; then
            sel=$(grep '^\*\*\*\*\* ' "${HOME}/org/contacts.org" | sed 's/^\*\*\*\*\* //' | rofi -dmenu -i -p 'у°ҲҚ	Contacts')
        else
            sel=$2
        fi

        # open contact
        if [ -n "${sel}" ] ; then
            sel=$(printf '%s' "${sel}" | sed 's/(/\\(/ ; s/)/\\)/')
            awk '
                BEGIN { FS="\n"; RS=""; OFS="\n"; ORS="\n" }
                {
                     for (i=1; i<=NF; i++) {
                         if ($i ~ /^\*\*\*\*\* '"${sel}"'$/) {
                            for (j=i+1; j<=NF; j++) {
                                if ($j ~ /^\*/) break
                                print $j
                            }
                        }
                    }
                }' "${HOME}/org/contacts.org" | \
                    yad --text-info --width=1600 --height=1000 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null
        fi
        ;;

    crt)
        # display a list of cool-retro-term profiles
        if [ $# -lt 2 ] ; then
            profiles=(
                "Default Amber"
                "Monochrome Green"
                "Green Scanlines"
                "Default Pixelated"
                "Apple ]["
                "Vintage"
                "IBM DOS"
                "IBM 3278"
                "Futuristic"
            )
            sel=$(printf '%s\n' "${profiles[@]}" | rofi -dmenu -i -p 'у°Қ№	Cool Retro Term')
        else
            sel=$2
        fi

        # launch cool-retro-term using selected profile
        if [ -n "${sel}" ] ; then
            (cool-retro-term --profile "${sel}" &)
        fi
        ;;

    dosbox)
        # generate and display a list of dosbox emulators
        if [ $# -lt 2 ] ; then
            sel=$(
                cd "${HOME}/.dosbox" &&
                    find -mindepth 1 -maxdepth 1 -name 'dosbox-*' -not -regex '\./dosbox-0.*' |
                        sed 's%^\./dosbox-\(.*\)\.conf%\1%' | rofi -dmenu -i -p 'оҳ©	DOSBox'
               )
        else
            sel=$2
        fi

        # launch selected dosbox emulator
        if [ -n "${sel}" ] ; then
            (dosbox -conf "${HOME}/.dosbox/dosbox-0.74-3.conf" -conf "${HOME}/.dosbox/dosbox-${sel}.conf" &)
        fi
        ;;

    emoji)
        # run rofimoji
        rofimoji --typer xdotool --clipboarder xsel --skin-tone neutral
        ;;

    footnotes)
        # copy selected footnote symbol to the clipboard
        footnotes=(
            "вңұ	Asterisk"
            "вҖ 	Dagger"
            "вҖЎ	Double Dagger"
            "В§	Section Mark"
            "В¶	Paragraph Symbol"
            "вҖ–	Parallel Lines"
            "#	Number Sign"
            "вңұвңұ	Double Asterisk"
            "вҖ вҖ 	Double Dagger"
            "вҖЎвҖЎ	Double Double Dagger"
            "В§В§	Double Section Mark"
            "В¶В¶	Double Paragraph Symbol"
            "вҖ–вҖ–	Double Parallel Lines"
            "##	Double Number Sign"
        )
        printf '%s\n' "${footnotes[@]}" | rofi -dmenu -i -p 'у°Ҫ’	Footnotes' | sed -z 's/\t.*$// ; s/\\n$//' | xsel && xsel --output | xsel --clipboard
        ;;

    git)
        # display git repositories
        if [ $# -lt 2 ] ; then
            sel=$(grep "# *git-sync" "${HOME}/.funct" | cut -d " " -f 9 | rofi -dmenu -i -p 'п„Ұ	Git')
        else
            sel=$2
        fi

        # synchronize with selected git repository
        if [ -n "${sel}" ] ; then
            source "${HOME}/.funct" && (eval "${sel}" && echo "Done") 2>&1 | yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null
        fi
        ;;

    home)
        # display home page bookmarks
        if [ $# -lt 2 ] ; then
            sel=$(cat "${HOME}/home-pages/"{home,dev}.html | sed -n '/<a id=/p' | sed 's/^.*<a id=\"id__\(.*\)__\([^"]*\)\".*$/\1: \2/; s/_/ /g' | rofi -dmenu -i -p 'вҢӮ	Home Page')
        else
            sel=$2
        fi

        # open bookmark
        if [ -n "${sel}" ] ; then
            id=$(printf '%s' "${sel}" | sed 's/ /_/g ; s/:_/__/ ; s/^/id__/')
            url=$(grep "${id}" "${HOME}/home-pages/"{home,dev}.html | sed 's/^.* href=\"\([^"]*\)\".*$/\1/')
            (xdg-open "${url}" &)
        fi
        ;;

    paste)
        # display paste options
        if [ $# -lt 2 ] ; then
            sel=$(cat "${HOME}/.paste-strings" | rofi -dmenu -i -p 'пғӘ	Paste')
        else
            sel=$2
        fi

        # copy paste selection to the clipboard
        if [ -n "${sel}" ] ; then
            printf '%s' "${sel}" | xsel && xsel --output | xsel --clipboard
        fi
        ;;

    password)
        # display password options
        if [ $# -lt 2 ] ; then
            passwords=(
                "6 Capitalized/Hyphenated Word Phrase"
                "4 Capitalized/Hyphenated Word Phrase"
                "20 Letters/Numbers/Symbols"
            )
            sel=$(printf '%s\n' "${passwords[@]}" | rofi -dmenu -i -p 'оҷІ	Password')
        else
            sel=$2
        fi

        # copy password selection to the clipboard
        if [ -n "${sel}" ] ; then
            case "${sel}" in
                "6 Capitalized/Hyphenated Word Phrase")
                    printf '%s' "$(${HOME}/bin/password-phrase 6 hyphen true)" | xsel && xsel --output | xsel --clipboard
                    ;;
                "4 Capitalized/Hyphenated Word Phrase")
                    printf '%s' "$(${HOME}/bin/password-phrase 4 hyphen true)" | xsel && xsel --output | xsel --clipboard
                    ;;
                "20 Letters/Numbers/Symbols")
                    tr --delete --complement 'a-zA-Z0-9!@#$%^&*-_=+;:,<.>/?' < /dev/urandom | \
                        head --bytes 20 | xsel && xsel --output | xsel --clipboard
                    ;;
            esac
        fi
        ;;

    qemu)
        # generate and display a list of qemu emulators
        if [ $# -lt 2 ] ; then
            sel=$(
                cd "${HOME}/qemu" && find . -mindepth 1 -maxdepth 1 -type d -not -regex '^\.+$' | sed 's%\./%%' | sort | rofi -dmenu -i -p 'у°Ҷ§	Qemu')
        else
            sel=$2
        fi

        # launch selected qemu emulator
        if [ -n "${sel}" ] ; then
            (cd "${HOME}/qemu/${sel}" && ./run &)
        fi
        ;;

    rsync)
        # display rsync targets
        if [ $# -lt 2 ] ; then
            sel=$(grep "^# *rsync-" ${HOME}/.alias | cut -d " " -f 9 | rofi -dmenu -i -p 'пғ¬	Rsync')
        else
            sel=$2
        fi

        # synchronize with selected rsync targets
        if [ -n "${sel}" ] ; then
            home="$(cd ${HOME} ; cd .. ; pwd)"
            cmd=$(cat "${HOME}/.alias" | sed ':a;N;$!ba;s/\\\n//g' | sed -n '/alias '"${sel}"'/p' | sed 's/^alias '"${sel}"'="// ; s/"$//')
            (eval "${cmd}" && echo "Done") 2>&1 | yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null
        fi
        ;;

    sounds)
        sounddirs=(
            "${HOME}/Sounds"
            "${HOME}/sounds"
        )
        stop="[Stop Player]"
        up="[..]"

        # generate and display a list of sound files and directories to choose from
        _select() {
            if [ -z "${sel}" ] ; then
                local opts=(
                    "${stop}"
                    "$(cd "${sounddir}" && find . -mindepth 1 -maxdepth 1 -type d -not -regex '^\.+$' | sed 's%^\./\(.*\)$%[\1]%' | sort)"
                    "$(cd "${sounddir}" && find . -mindepth 1 -maxdepth 1 -type f -not -regex '^\.+$' | sed 's%^\./%%' | sort)"
                )
            else
                local opts=("${up}" "$(cd "${selpath}" && find . -mindepth 1 -maxdepth 1 -type f -not -regex '^\.+$' | sed 's%./%%' | sort)")
            fi
            sel=$(printf '%s\n' "${opts[@]}" | rofi -dmenu -i -p 'у°қҡ	Sounds')
        }

        _killffplay() {
            # stop any currently playing sounds
            # (regardless of selection to prevent sounds from doubling up)
            pkill -u ${USER} ffplay || true
        }

        # find sound directory
        sounddir=
        for dir in "${sounddirs[@]}" ; do
            [ -z "${sounddir}" ] && [ -d "${dir}" ] && sounddir="${dir}"
        done
        [ -z "${sounddir}" ] && exit 1

        # generate and display a list of sound files and directories to choose from
        selpath="${sounddir}"
        if [ $# -lt 2 ] ; then
            sel=""
            _select
        else
            sel="$2"
        fi

        # process selection
        if [ -n "${sel}" ] ; then
            while true ; do
                if [ -z "${sel}" ] ; then
                    _select
                fi

                sel=$(printf '%s' "${sel}" | sed 's%^\[%% ; s%\]$%%')
                selpath="${sounddir}/${sel}"

                if [ "${sel}" == "${stop}" ] ; then
                    _killffplay
                    break
                fi

                # handle going up a directory
                if [ "${sel:0-${#up}}" == "${up}" ] ; then
                    dirlen=$((${#selpath}-${#up}-1))
                    dir="${selpath:0:${dirlen}}"
                    updir="$(cd "${dir}" && cd .. && pwd)"
                    sel="${updir:${#sounddir}}"
                    continue
                fi

                # handle traversing into a directory
                if [ -d "${selpath}" ] ; then
                    dir="${sel}"
                    _select
                    sel="${dir}/${sel}"
                    continue
                fi

                # handle playing a sound file
                _killffplay
                if $(printf '%s' "${sel}" | grep -q "Ambient Sound Effects") ; then
                    echo "Playing: ${sel} (in a loop)"
                    ffplay -nodisp -loop 0 "${selpath}"
                else
                    echo "Playing: ${sel}"
                    ffplay -nodisp -autoexit "${selpath}"
                fi
                break
            done
        fi
        ;;

    spell)
        if [ $# -lt 2 ] ; then
            sel=$(yad --title "Spell" --entry --text "Word to spell and define:" --fontname='MesloLGS Nerd Font Mono 14' 2>/dev/null)
        else
            sel=$2
        fi

        res=$(printf '%s' "${sel}" | ispell -a | tail -n -1)

        word=""
        case "${res:0:1}" in
            \*) word="${sel}" ;;
            \+) word="${res:1}" ;;
            \#) yad --title "Word" --text "Word ${sel} was not found" --fontname='MesloLGS Nerd Font Mono 14' 2>/dev/null ;;
            \?|\&) word=$(printf '%s' "${res}" | sed 's/^.*: // ; s/, */,/g' | tr ',' '\n' | rofi -dmenu -i -p 'о©ў	Select Word to Define') ;;
        esac

        [ -n "${word}" ] && trans -no-ansi "${word}" | yad --title "Definition" --text-info --width=1024 --height=768 --wrap --no-buttons --wrap --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null
        ;;

    ssh)
        if [ $# -lt 2 ] ; then
            servers=(
                "user@kali-direct"
                "user@mouse"
                "user@switch-direct"
                "pi@pimodem"
                "pi@raspad"
                "pi@raspad-usb"
                "kyle@159.203.165.79"
            )
            sel=$(printf '%s\n' "${servers[@]}" | rofi -dmenu -i -p 'оҡғ	SSH')
        else
            sel=$2
        fi

        # launch selected ssh connection
        if [ -n "${sel}" ] ; then
            (alacritty -t "SSH ${sel}" -e "ssh" "${sel}" &)
        fi
        ;;

    typer)
        # run rofi-typer
        ${HOME}/bin/rofi-typer
        ;;

    unicode)
        # run unipicker
        unipicker --command "rofi -dmenu -i -p 'U	Unicode'" --copy-command 'xsel'
        ;;

    vnc)
        if [ $# -lt 2 ] ; then
            servers=(
                "kali-direct"
                "pimodem"
                "raspad"
                "raspad-usb"
                "switch-direct"
            )
            sel=$(printf '%s\n' "${servers[@]}" | rofi -dmenu -i -p 'у°ӣҮ	VNC')
        else
            sel=$2
        fi

        # launch selected vnc connection
        if [ -n "${sel}" ] ; then
            (vncviewer "${sel}:0" &)
        fi
        ;;
esac

exit 0

