#!/usr/bin/env bash
#===============================================================================
# rofi-menu
#
# Present a menu of rofi menus.
#
# Symbols: ’āē Ōś░ ’ü╗ | ’āä ’āģ ’āå | Ō£é ŌÄś ¾░äČ ŅŁē ’ā¬ ¾░ģī ¾░ģŹ ¾░©Ė ¾▒ēź ¾▒ē” ¾▒ē¦ ¾▒ē© ¾▒ē½ ¾▒ē¼ ’āå | ŅÖ▓
# Symbols: ¾░Ź╣ ŅÜā Ņ×Ģ Ņ¬ģ | Ņś® | ’ä” ’Éś ’ÉÖ ¾▒ćĀ ’Ŗć | ¾░å¦ | ’ā¼ | ’ÄĄ ’Ćü ¾░ØÜ | ¾░øć | ¾░āā ¾░āĆ | ¾░»½ ¾░łŹ ŅŁĮ ’äŁ ¾░Ć¼ Ņ®ó Ļō┤ | Ōīé | ¾░ĮÆ
#
# Required utilities:
#   cool-retro-term
#   curl
#   dosbox
#   ffplay
#   rofi
#   trans
#   unipicker
#   vncviewer
#   xdg-utils
#
# Author: Kyle W T Sherman <kylewsherman@gmail.com>
#===============================================================================

set -eu #o pipefail

prompt="rofi -dmenu -i -p"
promptprefix="rofi -dmenu -matching prefix -i -p"

if [ "${XDG_SESSION_TYPE}" == "wayland" ] ; then
    clip="wl-copy"
    typer="wtype"
else
    clip="xsel && xsel --output | xsel --clipboard"
    typer="xdotool"
fi

# display usage information
_usage() {
    cat <<EOF
Usage: $(basename "$0") [MENU]
Present a menu of rofi menus.
MENU:
  NONE                Menu of Selections
  terminal            Terminal
  acronyms-computing  Acronyms: Computing
  bookmarks           Bookmarks
  bookmarks-keyword   Bookmarks: Keyword
  clipboard           Clipboard
  contacts            Contacts
  crt                 Cool Retro Term
  dosbox              DOSBox Emulator
  emoji               Emoji Search
  footnotes           Footnote Symbols
  git                 Synchronize Repositories
  home                Home Page Bookmarks
  paste               Paste Strings
  password            Generate Password
  qemu                QEMU Emulator
  rsync               Synchronize Files
  sounds              Play Sounds
  spell               Spell Check & Definition
  ssh                 SSH into Systems
  typer               Type Strings
  unicode             Unicode Search
  vnc                 VNC into Systems
EOF
}

# handle no arguments given
if [ $# -lt 1 ] ; then
    menus=(
        "ŅÜā	Terminal"
        "¾░»½	Acronyms: Computing"
        "¾░āā	Bookmarks"
        "¾░āā	Bookmarks: Keyword"
        "¾░åÆ	Clipboard"
        "¾░łŹ	Contacts"
        "¾░Ź╣	CRT"
        "Ņś®	DOSBox"
        "­¤śā	Emoji"
        "¾░ĮÆ	Footnotes"
        "’ä”	Git"
        "Ōīé	Home"
        "’ā¬	Paste"
        "ŅÖ▓	Password"
        "¾░å¦	Qemu"
        "’ā¼	Rsync"
        "¾░ØÜ	Sounds"
        "Ņ®ó	Spell"
        "ŅÜā	SSH"
        "ŅŁĮ	Typer"
        "U	Unicode"
        "¾░øć	VNC"
    )
    menu=$(printf '%s\n' "${menus[@]}" | ${prompt} '’āē	Menu')
else
    menu=$1
fi

# handle menu
menu=$(printf '%s' "${menu}" | sed 's/^.*\t//' | tr '[:upper:]' '[:lower:]' | tr -d ':' | tr ' ' '-')
#echo "${menu}"
case "${menu}" in
    terminal)
        (alacritty & disown)
        ;;

    acronyms-computing)
        (
            curl --silent "https://en.wikipedia.org/wiki/List_of_computing_and_IT_abbreviations" |
                grep "^<li>" |
                grep "/wiki/" |
                sed 's%^<li><a[^>]\+>\(.\+\)</a>\(.\+\)</li>%\1: \2% ;
                    s%ŌĆö%%g ; s%</ul>%% ; s%</\?b>%%g ; s%\&amp;%\&% ;
                    s%<sup .*</sup>%%g ; s%</div>%%g ; s%</a>$%% ;
                    s%<a [^>]*>%% ; s%</a>%: %' |
                grep -v '^<li>' | $(${prompt} '¾░»½	Acronyms: Computing')
        )
        ;;

    bookmarks)
        # display bookmarks
        if [ $# -lt 2 ] ; then
            sel=$(cat "${HOME}/Documents/bookmarks.txt" | ${prompt} '¾░āā	Bookmarks')
        else
            sel=$2
        fi

        # open bookmark
        if [ -n "${sel}" ] ; then
            url=$(printf '%s' "${sel}" | sed 's/^.* \([^ ]*$\)/\1/')
            (xdg-open "${url}" & disown)
        fi
        ;;

    bookmarks-keyword)
        # display bookmarks having keywords
        if [ $# -lt 2 ] ; then
            sel=$(sed -n 's/^.* {\(.*\)}: /\1 -> /p' "${HOME}/Documents/bookmarks.txt" | \
                      sort | ${promptprefix} '¾░āā	Bookmarks: Keyword')
        else
            sel=$2
        fi

        # open bookmark
        if [ -n "${sel}" ] ; then
            url=$(printf '%s' "${sel}" | sed 's/^.* \([^ ]*$\)/\1/')
            (xdg-open "${url}" & disown)
        fi
        ;;

    clipboard)
        case "${XDG_SESSION_TYPE}" in
            wayland)
                # display clipboard
                if [ $# -lt 2 ] ; then
                    sel=$(dms clipboard history | \
                              awk '/^ID: /{ key=$0; getline; print key $0; next } { print }' | \
                              grep '| text |' | sed 's/^ID: // ; s/ | text | .*  /: /' | \
                              ${promptprefix} '¾░åÆ	Clipboard')
                else
                    sel=$2
                fi

                # paste clip
                if [ -n "${sel}" ] ; then
                    id=$(printf '%s' "${sel}" | sed 's/^\([0-9]\+\).*$/\1/')
                    dms clipboard get ${id} --copy && dms clipboard paste
                fi
                ;;

            *)
                CM_LAUNCHER=rofi clipmenu
                ;;
        esac
        ;;

    contacts)
        # display contacts
        if [ $# -lt 2 ] ; then
            sel=$(grep '^\*\*\*\*\* ' "${HOME}/org/contacts.org" | \
                      sed 's/^\*\*\*\*\* //' | ${prompt} '¾░łŹ	Contacts')
        else
            sel=$2
        fi

        # open contact
        if [ -n "${sel}" ] ; then
            sel=$(printf '%s' "${sel}" | sed 's/(/\\(/ ; s/)/\\)/')
            awk '
                BEGIN { FS="\n"; RS=""; OFS="\n"; ORS="\n" }
                {
                     for (i=1; i<=NF; i++) {
                         if ($i ~ /^\*\*\*\*\* '"${sel}"'$/) {
                            for (j=i+1; j<=NF; j++) {
                                if ($j ~ /^\*/) break
                                print $j
                            }
                        }
                    }
                }' "${HOME}/org/contacts.org" | \
                    (GDK_BACKEND=x11 \
                         yad --text-info --width=1600 --height=1000 \
                         --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' \
                         --tail 2>/dev/null & disown)
        fi
        ;;

    crt)
        # display a list of cool-retro-term profiles
        if [ $# -lt 2 ] ; then
            profiles=(
                "Default Amber"
                "Monochrome Green"
                "Green Scanlines"
                "Default Pixelated"
                "Apple ]["
                "Vintage"
                "IBM DOS"
                "IBM 3278"
                "Futuristic"
            )
            sel=$(printf '%s\n' "${profiles[@]}" | ${prompt} '¾░Ź╣	Cool Retro Term')
        else
            sel=$2
        fi

        # launch cool-retro-term using selected profile
        if [ -n "${sel}" ] ; then
            (cool-retro-term --profile "${sel}" & disown)
        fi
        ;;

    dosbox)
        # generate and display a list of dosbox emulators
        if [ $# -lt 2 ] ; then
            sel=$(
                cd "${HOME}/.dosbox" &&
                    find -mindepth 1 -maxdepth 1 -name 'dosbox-*' -not -regex '\./dosbox-0.*' |
                        sed 's%^\./dosbox-\(.*\)\.conf%\1%' | $(${prompt} 'Ņś®	DOSBox')
               )
        else
            sel=$2
        fi

        # launch selected dosbox emulator
        if [ -n "${sel}" ] ; then
            (dosbox -conf "${HOME}/.dosbox/dosbox-0.74-3.conf" -conf "${HOME}/.dosbox/dosbox-${sel}.conf" & disown)
        fi
        ;;

    emoji)
        # run rofimoji
        if [ "${XDG_SESSION_TYPE}" == "wayland" ] ; then
            (rofimoji --typer wtype --clipboarder wl-copy --action copy --skin-tone neutral & disown)
        else
            (rofimoji --typer xdotool --clipboarder xsel --action copy --skin-tone neutral & disown)
        fi
        ;;

    footnotes)
        # copy selected footnote symbol to the clipboard
        footnotes=(
            "Ō£▒	Asterisk"
            "ŌĆĀ	Dagger"
            "ŌĆĪ	Double Dagger"
            "┬¦	Section Mark"
            "┬Č	Paragraph Symbol"
            "ŌĆ¢	Parallel Lines"
            "#	Number Sign"
            "Ō£▒Ō£▒	Double Asterisk"
            "ŌĆĀŌĆĀ	Double Dagger"
            "ŌĆĪŌĆĪ	Double Double Dagger"
            "┬¦┬¦	Double Section Mark"
            "┬Č┬Č	Double Paragraph Symbol"
            "ŌĆ¢ŌĆ¢	Double Parallel Lines"
            "##	Double Number Sign"
        )
        (printf '%s\n' "${footnotes[@]}" | ${prompt} '¾░ĮÆ	Footnotes' | sed -z 's/\t.*$// ; s/\\n$//' | ${clip})
        ;;

    git)
        # display git repositories
        if [ $# -lt 2 ] ; then
            sel=$(grep "# *git-sync" "${HOME}/.funct" | cut -d " " -f 9 | ${prompt} '’ä”	Git')
        else
            sel=$2
        fi

        # synchronize with selected git repository
        if [ -n "${sel}" ] ; then
            (source "${HOME}/.funct" && (eval "${sel}" && echo "Done") 2>&1 | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null & disown)
        fi
        ;;

    home)
        # display home page bookmarks
        if [ $# -lt 2 ] ; then
            sel=$(cat "${HOME}/home-pages/"{home,dev}.html | sed -n '/<a id=/p' | \
                      sed 's/^.*<a id=\"id__\(.*\)__\([^"]*\)\".*$/\1: \2/; s/_/ /g' | \
                      ${prompt} 'Ōīé	Home Page')
        else
            sel=$2
        fi

        # open bookmark
        if [ -n "${sel}" ] ; then
            id=$(printf '%s' "${sel}" | sed 's/ /_/g ; s/:_/__/ ; s/^/id__/')
            url=$(grep "${id}" "${HOME}/home-pages/"{home,dev}.html | sed 's/^.* href=\"\([^"]*\)\".*$/\1/')
            (xdg-open "${url}" & disown)
        fi
        ;;

    paste)
        # display paste options
        if [ $# -lt 2 ] ; then
            sel=$(cat "${HOME}/.paste-strings" | ${prompt} '’ā¬	Paste')
        else
            sel=$2
        fi

        # copy paste selection to the clipboard
        if [ -n "${sel}" ] ; then
            (printf '%s' "${sel}" | ${clip})
        fi
        ;;

    password)
        # display password options
        if [ $# -lt 2 ] ; then
            passwords=(
                "6 Capitalized/Hyphenated Word Phrase"
                "4 Capitalized/Hyphenated Word Phrase"
                "20 Letters/Numbers/Symbols"
            )
            sel=$(printf '%s\n' "${passwords[@]}" | ${prompt} 'ŅÖ▓	Password')
        else
            sel=$2
        fi

        # copy password selection to the clipboard
        if [ -n "${sel}" ] ; then
            case "${sel}" in
                "6 Capitalized/Hyphenated Word Phrase")
                    (printf '%s' "$(${HOME}/bin/password-phrase 6 hyphen true)" | ${clip})
                    ;;
                "4 Capitalized/Hyphenated Word Phrase")
                    (printf '%s' "$(${HOME}/bin/password-phrase 4 hyphen true)" | ${clip})
                    ;;
                "20 Letters/Numbers/Symbols")
                    (tr --delete --complement 'a-zA-Z0-9!@#$%^&*-_=+;:,<.>/?' < /dev/urandom | head --bytes 20 | ${clip})
                    ;;
            esac
        fi
        ;;

    qemu)
        # generate and display a list of qemu emulators
        if [ $# -lt 2 ] ; then
            sel=$(
                cd "${HOME}/qemu" && find . -mindepth 1 -maxdepth 1 -type d -not -regex '^\.+$' | \
                        sed 's%\./%%' | sort | ${prompt} '¾░å¦	Qemu')
        else
            sel=$2
        fi

        # launch selected qemu emulator
        if [ -n "${sel}" ] ; then
            (cd "${HOME}/qemu/${sel}" && ./run & disown)
        fi
        ;;

    rsync)
        # display rsync targets
        if [ $# -lt 2 ] ; then
            sel=$(grep "^# *rsync-" ${HOME}/.alias | cut -d " " -f 9 | ${prompt} '’ā¼	Rsync')
        else
            sel=$2
        fi

        # synchronize with selected rsync targets
        if [ -n "${sel}" ] ; then
            home="$(cd ${HOME} ; cd .. ; pwd)"
            cmd=$(cat "${HOME}/.alias" | sed ':a;N;$!ba;s/\\\n//g' | sed -n '/alias '"${sel}"'/p' | sed 's/^alias '"${sel}"'="// ; s/"$//')
            ((eval "${cmd}" && echo "Done") 2>&1 | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null & disown)
        fi
        ;;

    sounds)
        sounddirs=(
            "${HOME}/Sounds"
            "${HOME}/sounds"
        )
        stop="[Stop Player]"
        up="[..]"

        # generate and display a list of sound files and directories to choose from
        _select() {
            if [ -z "${sel}" ] ; then
                local opts=(
                    "${stop}"
                    "$(cd "${sounddir}" && find . -mindepth 1 -maxdepth 1 -type d -not -regex '^\.+$' | sed 's%^\./\(.*\)$%[\1]%' | sort)"
                    "$(cd "${sounddir}" && find . -mindepth 1 -maxdepth 1 -type f -not -regex '^\.+$' | sed 's%^\./%%' | sort)"
                )
            else
                local opts=("${up}" "$(cd "${selpath}" && find . -mindepth 1 -maxdepth 1 -type f -not -regex '^\.+$' | sed 's%./%%' | sort)")
            fi
            sel=$(printf '%s\n' "${opts[@]}" | ${prompt} '¾░ØÜ	Sounds')
        }

        _killffplay() {
            # stop any currently playing sounds
            # (regardless of selection to prevent sounds from doubling up)
            pkill -u ${USER} ffplay || true
        }

        # find sound directory
        sounddir=
        for dir in "${sounddirs[@]}" ; do
            [ -z "${sounddir}" ] && [ -d "${dir}" ] && sounddir="${dir}"
        done
        [ -z "${sounddir}" ] && exit 1

        # generate and display a list of sound files and directories to choose from
        selpath="${sounddir}"
        if [ $# -lt 2 ] ; then
            sel=""
            _select
        else
            sel="$2"
        fi

        # process selection
        if [ -n "${sel}" ] ; then
            while true ; do
                if [ -z "${sel}" ] ; then
                    _select
                fi

                sel=$(printf '%s' "${sel}" | sed 's%^\[%% ; s%\]$%%')
                selpath="${sounddir}/${sel}"

                if [ "${sel}" == "${stop}" ] ; then
                    _killffplay
                    break
                fi

                # handle going up a directory
                if [ "${sel:0-${#up}}" == "${up}" ] ; then
                    dirlen=$((${#selpath}-${#up}-1))
                    dir="${selpath:0:${dirlen}}"
                    updir="$(cd "${dir}" && cd .. && pwd)"
                    sel="${updir:${#sounddir}}"
                    continue
                fi

                # handle traversing into a directory
                if [ -d "${selpath}" ] ; then
                    dir="${sel}"
                    _select
                    sel="${dir}/${sel}"
                    continue
                fi

                # handle playing a sound file
                _killffplay
                if $(printf '%s' "${sel}" | grep -q "Ambient Sound Effects") ; then
                    echo "Playing: ${sel} (in a loop)"
                    (ffplay -nodisp -loop 0 "${selpath}" & disown)
                else
                    echo "Playing: ${sel}"
                    (ffplay -nodisp -autoexit "${selpath}" & disown)
                fi
                break
            done
        fi
        ;;

    spell)
        if [ $# -lt 2 ] ; then
            sel=$(GDK_BACKEND=x11 yad --title "Spell" --entry --text "Word to spell and define:" --fontname='MesloLGS Nerd Font Mono 14' 2>/dev/null)
        else
            sel=$2
        fi

        res=$(printf '%s' "${sel}" | ispell -a | tail -n -1)

        word=""
        case "${res:0:1}" in
            \*) word="${sel}" ;;
            \+) word="${res:1}" ;;
            \#) GDK_BACKEND=x11 yad --title "Word" --text "Word ${sel} was not found" --fontname='MesloLGS Nerd Font Mono 14' 2>/dev/null ;;
            \?|\&) word=$(printf '%s' "${res}" | sed 's/^.*: // ; s/, */,/g' | tr ',' '\n' | ${prompt} 'Ņ®ó	Select Word to Define') ;;
        esac

        [ -n "${word}" ] && trans -no-ansi "${word}" | \
                (GDK_BACKEND=x11 \
                     yad --title "Definition" --text-info \
                     --width=1024 --height=768 --wrap --no-buttons \
                     --wrap --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null & disown)
        ;;

    ssh)
        if [ $# -lt 2 ] ; then
            servers=(
                "user@kali-direct"
                "user@mouse"
                "user@switch-direct"
                "pi@pimodem"
                "pi@raspad"
                "pi@raspad-usb"
                "kyle@159.203.165.79"
            )
            sel=$(printf '%s\n' "${servers[@]}" | ${prompt} 'ŅÜā	SSH')
        else
            sel=$2
        fi

        # launch selected ssh connection
        if [ -n "${sel}" ] ; then
            (alacritty -t "SSH ${sel}" -e "ssh" "${sel}" & disown)
        fi
        ;;

    typer)
        # run rofi-typer
        ${HOME}/bin/rofi-typer
        ;;

    unicode)
        # run unipicker
        if [ "${XDG_SESSION_TYPE}" == "wayland" ] ; then
            (unipicker --command "${prompt} 'U	Unicode'" --copy-command 'wl-copy' & disown)
        else
            (unipicker --command "${prompt} 'U	Unicode'" --copy-command 'xsel' & disown)
        fi
        ;;

    vnc)
        if [ $# -lt 2 ] ; then
            servers=(
                "kali-direct"
                "pimodem"
                "raspad"
                "raspad-usb"
                "switch-direct"
            )
            sel=$(printf '%s\n' "${servers[@]}" | ${prompt} '¾░øć	VNC')
        else
            sel=$2
        fi

        # launch selected vnc connection
        if [ -n "${sel}" ] ; then
            (vncviewer "${sel}:0" & disown)
        fi
        ;;
esac

exit 0

