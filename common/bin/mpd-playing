#!/usr/bin/env bash
#===============================================================================
# mpd-playing
#
# Print currently playing Music Player Daemon song.
#
# Author: Kyle W T Sherman <kylewsherman@gmail.com>
#===============================================================================

if [ "$1" == "-h" ] || [ "$1" == "--help" ] ; then
    echo "Usage: $(basename $0) [-nt,--notify-title] [-nb,--notify-body] [-v,--verbose]"
    echo "  -nt,--notify-title - Title for notify-send"
    echo "  -nb,--notify-body  - Body for notify-send"
    echo "  -v,--verbose       - Verbose output"
    exit 0
fi

[ $(mpc | wc -l) != 3 ] && echo -n "-" && exit 1

song=$(mpc -f '[[%artist% - ]%title%]|[%file%]' | sed -n 1p)
artist=$(mpc -f '%artist%' | sed -n 1p)
album=$(mpc -f '%album%' | sed -n 1p)
title=$(mpc -f '%title%' | sed -n 1p)
status=$(mpc | sed -n 2p)
state=$(echo "${status}" | sed 's/^\[\(.*\)\].*$/\1/')
num=$(echo "${status}" | sed 's/^.*#\([^ ]*\).*$/\1/')
pct=$(echo "${status}" | sed 's/^.*(\(.*\)).*$/\1/')
pct="0${pct}"
pct="${pct: -3}"
file=$(mpc -f '%file%' | sed -n 1p)
rating=$(grep -F "${file}" ${HOME}/.song-ratings/* | sed 's/^.*songs-rated-\([0-9]\).*$/\1/')

if [ "$1" == "-v" ] || [ "$1" == "--verbose" ] ; then
    printf 'Artist: %s\n' "${artist}"
    printf 'Album: %s\n' "${album}"
    printf 'Title: %s\n' "${title}"
    printf 'Rating: %s\n' "${rating}"
    printf 'State: %s\n' "${state}"
    printf 'Number: %s\n' "${num}"
    printf 'Percentage: %s\n' "${pct}"
    printf 'File: %s\n' "${file}"
    exit 0
fi

if [ "$1" == "-nt" ] || [ "$1" == "--notify-title" ] ; then
    printf '%s' "${title}"
elif [ "$1" == "-nb" ] || [ "$1" == "--notify-body" ] ; then
    printf '%s\n[%s] %s %s' "${artist}" "${rating}" "${num}" "${pct}"
else
    printf '%s [%s] %s %s\n' "${song}" "${rating}" "${num}" "${pct}"
fi

#===============================================================================
# End of File
#===============================================================================
