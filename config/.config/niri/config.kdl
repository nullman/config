//======================================================================
// Niri Configuration
//
// This config is in the KDL format: https://kdl.dev
// "/-" comments out the following node
//
// Check the wiki for a full description of the configuration:
//   https://niri-wm.github.io/niri/Configuration:-Introduction
//======================================================================

input {
    keyboard {
        // fetch xkb settings from org.freedesktop.locale1; set with ~localectl set-x11-keymap~
        xkb { }

        repeat-delay 500
        repeat-rate  35

        // enable numlock on startup
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {
    }

    trackpoint {
    }
}

switch-events {
    lid-close { spawn "swaylock"; }
    //lid-open { }
    //tablet-mode-on { spawn "bash" "-c" "gsettings set org.gnome.desktop.a11y.applications screen-keyboard-enabled true"; }
    //tablet-mode-off { spawn "bash" "-c" "gsettings set org.gnome.desktop.a11y.applications screen-keyboard-enabled false"; }
}

// list outputs with ~niri msg outpus~
/-output "eDP-1" {
    mode "1920x1080@120.030"
    scale 2
    transform "normal"
    position x=1280 y=0
}

layout {
    gaps 8

    // when to center a column when changing focus: never, always, on-overflow
    center-focused-column "on-overflow"

    // widths that ~switch-preset-column-width~ (Mod+R) toggles between
    preset-column-widths {
        //proportion 0.33333
        proportion 0.5
        //proportion 0.66667
        proportion 1.0
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
    }

    border {
        off
        width 4
        active-color "#ffc87f"
        inactive-color "#505050"
        urgent-color "#9b0000"
    }

    shadow {
        off
        // draw-behind-window true
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }

    struts {
        // left 64
        // right 64
        // top 64
        // bottom 64
    }
}

recent-windows {
    debounce-ms 750

    open-delay-ms 150

    highlight {
        active-color "#999999ff"
        urgent-color "#ff9999ff"
        padding 30
        corner-radius 0
    }

    previews {
        max-height 480
        max-scale 0.5
    }

    binds {
        Alt+Tab         { next-window     scope="workspace"; }
        Alt+Shift+Tab   { previous-window scope="workspace"; }

        Mod+Tab         { next-window     scope="output"; }
        Mod+Shift+Tab   { previous-window scope="output"; }
    }
}

// named workspaces
//           
workspace "term"   // ""
workspace "edit"   // ""
workspace "email"  // ""
workspace "browse" // ""
workspace "file"   // ""
workspace "chat"   // ""
workspace "dev"    // ""
//workspace "video"  // ""
//workspace "vm"     // ""

// startup applications
//spawn-at-startup "waybar"
//spawn-sh-at-startup "xscreensaver --splash"

// do not show hotkey list on startup
hotkey-overlay {
    skip-at-startup
    hide-not-bound
}

// hide mouse curor when typing
cursor {
    hide-when-typing
}

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

animations {
    slowdown 0.5                        // lower is faster; default is 1.0
}

// windows have rounded corners
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    match app-id="Yad"
    open-floating true
}

window-rule {
    match app-id="^bitwarden$"
    block-out-from "screen-capture"
}

window-rule {
    match app-id="x48"
    match app-id="x48ng"
    default-column-width { proportion 0.25; }
}

window-rule {
    match app-id="Alacritty"
    default-column-width { proportion 0.5; }
}

window-rule {
    match app-id="emacs"
    default-column-width { proportion 1.0; }
    open-on-workspace "edit"
}

window-rule {
    match app-id="net.thunderbird.Thunderbird"
    default-column-width { proportion 1.0; }
    open-on-workspace "email"
}

window-rule {
    match app-id="Chromium-browser"
    match app-id="Firefox"
    match app-id="Google-chrome"
    match app-id="LibreWolf"
    match app-id="brave-browser"
    default-column-width { proportion 1.0; }
    open-on-workspace "browse"
}

window-rule {
    match app-id="org.gnome.Nautilus"
    match app-id="Pcmanfm"
    match app-id="Spacefm"
    match app-id="thunar"
    match app-id="org.gnome.Papers"
    default-column-width { proportion 1.0; }
    open-on-workspace "file"
}

window-rule {
    match app-id="com.github.bleakgrey.tootle"
    match app-id="Element"
    match app-id="Gajim"
    match app-id="Pidgin"
    match app-id="slack"
    match app-id="dev.geopjr.Tuba"
    match app-id="discord"
    match app-id="gossip"
    match app-id="nheko"
    match app-id="quassel"
    default-column-width { proportion 0.5; }
    open-on-workspace "chat"
}

window-rule {
    match app-id="jetbrains-idea"
    match app-id="jetbrains-idea-ce"
    match app-id="jetbrains-studio"
    match app-id="xyz.chatboxapp.app"
    default-column-width { proportion 1.0; }
    open-on-workspace "dev"
}

window-rule {
    match app-id="Gimp-2.10"
    match app-id="mplayer2"
    match app-id="Qmmp"
    match app-id="spotify"
    default-column-width { proportion 0.5; }
    open-on-workspace "video"
}

window-rule {
    match app-id="VirtualBox Machine"
    match app-id="VirtualBox Manager"
    default-column-width { proportion 1.0; }
    open-on-workspace "vm"
}

binds {
    // use ~wev~ to find XKB key names
    //
    // "Mod" is a special modifier equal to Super when running on a TTY, and
    // to Alt when running as a winit window

    // help
    Super+Shift+Slash { show-hotkey-overlay; }
    Super+H           { show-hotkey-overlay; }

    // media keys: brightness
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // media keys: volume
    XF86AudioRaiseVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1-"; }
    XF86AudioMute        allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SOURCE@" "toggle"; }

    // media keys: audio play
    XF86AudioPrev allow-when-locked=true { spawn "playerctl" "previous"; }
    XF86AudioPlay allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioStop allow-when-locked=true { spawn "playerctl" "stop"; }
    XF86AudioNext allow-when-locked=true { spawn "playerctl" "next"; }

    // wooting lekker keyboard media keys: brightness
    Super+Print allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    Super+Pause allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // wooting lekker keyboard media keys: volume
    Super+Insert  allow-when-locked=true { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    Super+Home    allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1-"; }
    Super+Page_Up allow-when-locked=true { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1+"; }

    // wooting lekker keyboard media keys: audio play
    Super+Delete    allow-when-locked=true { spawn "playerctl" "previous"; }
    Super+End       allow-when-locked=true { spawn "playerctl" "play-pause"; }
    Super+Page_Down allow-when-locked=true { spawn "playerctl" "next"; }

    // screenshots
    Super+Alt+Print   { screenshot-screen; }
    Super+Ctrl+Print  { screenshot-window; }
    Super+Shift+Print { screenshot; }

    // applications & utilities
    Super+Ctrl+Space hotkey-overlay-title="Toggle Overview" repeat=false                      { toggle-overview; }
    Super+Alt+Space  hotkey-overlay-title="Window, Desktop Application, and Program Launcher" { spawn "rofi" "-show" "combi" "-modes" "combi" "-combi-modes" "'window,drun,run'"; }
    Super+T          hotkey-overlay-title="Alacritty Terminal"                                { spawn "alacritty"; }
    Super+D          hotkey-overlay-title="Desktop Application Launcher"                      { spawn "rofi" "-modi" "drun" "-show" "drun"; }
    Super+Shift+D    hotkey-overlay-title="Program Launcher"                                  { spawn "rofi" "-modi" "run" "-show" "run"; }
    Super+A          hotkey-overlay-title="Application Group Launcher"                        { spawn-sh "${HOME}/bin/application-launcher"; }
    Super+Return     hotkey-overlay-title="Menu Launcher"                                     { spawn-sh "${HOME}/bin/rofi-menu"; }
    Super+W          hotkey-overlay-title="Window Selector"                                   { spawn "rofi" "-modi" "window" "-show" "window"; }
    Super+C          hotkey-overlay-title="Clipboard Selector"                                { spawn-sh "${HOME}/bin/rofi-menu clipboard"; }
    Super+E          hotkey-overlay-title="Emoji Selector"                                    { spawn-sh "${HOME}/bin/rofi-menu emoji"; }
    Super+U          hotkey-overlay-title="Unicode Selector"                                  { spawn-sh "${HOME}/bin/rofi-menu unicode"; }
    Super+Shift+U    hotkey-overlay-title="Footnote Symbol Selector"                          { spawn-sh "${HOME}/bin/rofi-menu footnotes"; }
    Super+O          hotkey-overlay-title="Bookmarks Selector"                                { spawn-sh "${HOME}/bin/rofi-menu bookmarks"; }
    Super+Shift+O    hotkey-overlay-title="Bookmarks Keyword Selector"                        { spawn-sh "${HOME}/bin/rofi-menu bookmarks-keyword"; }
    Super+SemiColon  hotkey-overlay-title="Typer Selector"                                    { spawn-sh "${HOME}/bin/rofi-typer"; }
    Super+Apostrophe hotkey-overlay-title="Paste Selector"                                    { spawn-sh "${HOME}/bin/rofi-menu paste"; }
    Super+S          hotkey-overlay-title="Spell and Define Word"                             { spawn-sh "${HOME}/bin/rofi-menu spell"; }
    // bitwarden selector
    Super+P          hotkey-overlay-title="Generate Password"                                 { spawn-sh "${HOME}/bin/rofi-menu password"; }
    Super+Backslash  hotkey-overlay-title="Display Time"                                      { spawn-sh "printf \"$(date '+%Y-%m-%d')\n $(date '+%H:%M:%S')\" | GDK_BACKEND=x11 yad --text-info --width=532 --height=240 --wrap --no-buttons --timeout=3 --fontname='MesloLGS Nerd Font Mono 64' 2>/dev/null"; }
    Super+Y          hotkey-overlay-title="Git Sync: Config"                                  { spawn-sh "source \"${HOME}/.funct\" && (git-sync-config && echo 'Done') 2>&1 | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null"; }
    Super+Shift+Y    hotkey-overlay-title="Git Sync: Extra"                                   { spawn-sh "source \"${HOME}/.funct\" && (git-sync-extra && echo 'Done') 2>&1 | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null"; }
    Super+X          hotkey-overlay-title="Activate XScreenSaver"                             { spawn "xscreensaver-command" "-activate"; }
    Super+Alt+X      hotkey-overlay-title="XScreenSaver Demo"                                 { spawn "xscreensaver-demo"; }
    Super+Shift+X    hotkey-overlay-title="Screen Lock"                                       { spawn "swaylock"; }
    Super+Shift+W    hotkey-overlay-title="Close Window" repeat=false                         { close-window; }
    Super+Shift+Q    hotkey-overlay-title="Session Menu"                                      { spawn-sh "${HOME}/bin/rofi-session-menu -s"; }
    Super+Shift+P    hotkey-overlay-title="Window Properties"                                 { spawn-sh "notify-send --expire-time=3000 'Select window' ; niri msg pick-window | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null"; }
    Super+Shift+C    hotkey-overlay-title="Color Picker"                                      { spawn-sh "notify-send --expire-time=3000 'Select color' ; niri msg pick-color | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null"; }
    Super+Shift+V    hotkey-overlay-title="Validate Niri Config"                              { spawn-sh "niri validate 2>&1 | ansi2txt | GDK_BACKEND=x11 yad --text-info --width=1024 --height=768 --wrap --no-buttons --fontname='MesloLGS Nerd Font Mono 14' --tail 2>/dev/null"; }

    // mpd controls
    Super+Alt+Ctrl+M      hotkey-overlay-title="mpd: Play/Pause" { spawn-sh "mpc toggle && notify-send --expire-time=5000 --replace-id=2 --icon=/usr/share/icons/Adwaita/scalable/mimetypes/audio-x-generic.svg \"$(${HOME}/bin/mpd-playing --notify-title)\" \"$(${HOME}/bin/mpd-playing --notify-body)\""; }
    Super+Alt+Ctrl+Comma  hotkey-overlay-title="mpd: Previous"   { spawn-sh "mpc prev && notify-send --expire-time=5000 --replace-id=2 --icon=/usr/share/icons/Adwaita/scalable/mimetypes/audio-x-generic.svg \"$(${HOME}/bin/mpd-playing --notify-title)\" \"$(${HOME}/bin/mpd-playing --notify-body)\""; }
    Super+Alt+Ctrl+Period hotkey-overlay-title="mpd: Next"       { spawn-sh "mpc next && notify-send --expire-time=5000 --replace-id=2 --icon=/usr/share/icons/Adwaita/scalable/mimetypes/audio-x-generic.svg \"$(${HOME}/bin/mpd-playing --notify-title)\" \"$(${HOME}/bin/mpd-playing --notify-body)\""; }
    Super+Alt+Ctrl+Slash  hotkey-overlay-title="mpd: Notify"     { spawn-sh "notify-send --expire-time=5000 --replace-id=2 --icon=/usr/share/icons/Adwaita/scalable/mimetypes/audio-x-generic.svg \"$(${HOME}/bin/mpd-playing --notify-title)\" \"$(${HOME}/bin/mpd-playing --notify-body)\""; }

    // connect to sennheiser hd350bt headphones
    Super+B       hotkey-overlay-title="Connect to Sennheiser HD350BT Headphones"      { spawn-sh "notify-send --expire-time=3000 'Connecting to Sennheiser HD 350BT Headphones' && bluetoothctl connect 80:C3:BA:0E:CB:E5"; }
    Super+Shift+B hotkey-overlay-title="Disconnect from Sennheiser HD350BT Headphones" { spawn-sh "notify-send --expire-time=3000 'Disconnecting from Sennheiser HD 350BT Headphones' && bluetoothctl disconnect 80:C3:BA:0E:CB:E5"; }

    // connect to powerbeats pro headphones
    Super+N       hotkey-overlay-title="Connect to Powerbeats Pro Headphones"      { spawn-sh "notify-send --expire-time=3000 'Connecting to Powerbeats Pro Headphones' && bluetoothctl connect 14:1A:97:05:81:4C"; }
    Super+Shift+N hotkey-overlay-title="Disconnect from Powerbeats Pro Headphones" { spawn-sh "notify-send --expire-time=3000 'Disconnecting from Powerbeats Pro Headphones' && bluetoothctl disconnect 14:1A:97:05:81:4C"; }

    // window manager controls

    Alt+grave   { focus-workspace-previous; }
    Super+grave { focus-workspace-previous; }

    //Super+Up    { focus-window-up; }
    //Super+Down  { focus-window-down; }
    //Super+I     { focus-window-up; }
    //Super+K     { focus-window-down; }

    Super+Left      { focus-column-left; }
    Super+Right     { focus-column-right; }
    Super+Up        { focus-workspace-up; }
    Super+Down      { focus-workspace-down; }
    Super+J         { focus-column-left; }
    Super+L         { focus-column-right; }
    Super+I         { focus-workspace-up; }
    Super+K         { focus-workspace-down; }
    Super+Alt+Left  { focus-column-first; }
    Super+Alt+Right { focus-column-last; }
    Super+Alt+J     { focus-column-first; }
    Super+Alt+L     { focus-column-last; }

    //Super+Shift+Up    { move-window-up; }
    //Super+Shift+Down  { move-window-down; }
    //Super+Shift+I     { move-window-up; }
    //Super+Shift+K     { move-window-down; }

    Super+Shift+Left      { move-column-left; }
    Super+Shift+Right     { move-column-right; }
    Super+Shift+Up        { move-column-to-workspace-up; }
    Super+Shift+Down      { move-column-to-workspace-down; }
    Super+Shift+J         { move-column-left; }
    Super+Shift+L         { move-column-right; }
    Super+Shift+I         { move-column-to-workspace-up; }
    Super+Shift+K         { move-column-to-workspace-down; }
    Super+Alt+Shift+Left  { move-column-to-first; }
    Super+Alt+Shift+Right { move-column-to-last; }
    Super+Alt+Shift+J     { move-column-to-first; }
    Super+Alt+Shift+L     { move-column-to-last; }

    Super+Ctrl+Left  { focus-monitor-left; }
    Super+Ctrl+Right { focus-monitor-right; }
    Super+Ctrl+Up    { focus-monitor-up; }
    Super+Ctrl+Down  { focus-monitor-down; }
    Super+Ctrl+J     { focus-monitor-left; }
    Super+Ctrl+L     { focus-monitor-right; }
    Super+Ctrl+I     { focus-monitor-up; }
    Super+Ctrl+K     { focus-monitor-down; }

    Super+Ctrl+Shift+Left  { move-column-to-monitor-left; }
    Super+Ctrl+Shift+Right { move-column-to-monitor-right; }
    Super+Ctrl+Shift+Up    { move-column-to-monitor-up; }
    Super+Ctrl+Shift+Down  { move-column-to-monitor-down; }
    Super+Ctrl+Shift+J     { move-column-to-monitor-left; }
    Super+Ctrl+Shift+L     { move-column-to-monitor-right; }
    Super+Ctrl+Shift+I     { move-column-to-monitor-up; }
    Super+Ctrl+Shift+K     { move-column-to-monitor-down; }

    Super+Shift+Page_Up        { move-workspace-up; }
    Super+Shift+Page_Down      { move-workspace-down; }
    Super+Ctrl+Shift+Page_Up   { move-workspace-to-monitor-left; }
    Super+Ctrl+Shift+Page_Down { move-workspace-to-monitor-right; }

    Super+WheelScrollDown       cooldown-ms=150 { focus-workspace-down; }
    Super+WheelScrollUp         cooldown-ms=150 { focus-workspace-up; }
    Super+Shift+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Super+Shift+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }

    Super+WheelScrollLeft        { focus-column-left; }
    Super+WheelScrollRight       { focus-column-right; }
    Super+Shift+WheelScrollLeft  { move-column-left; }
    Super+Shift+WheelScrollRight { move-column-right; }

    Super+Ctrl+WheelScrollUp         { focus-column-left; }
    Super+Ctrl+WheelScrollDown       { focus-column-right; }
    Super+Ctrl+Shift+WheelScrollUp   { move-column-left; }
    Super+Ctrl+Shift+WheelScrollDown { move-column-right; }

    Super+1 { focus-workspace 1; }
    Super+2 { focus-workspace 2; }
    Super+3 { focus-workspace 3; }
    Super+4 { focus-workspace 4; }
    Super+5 { focus-workspace 5; }
    Super+6 { focus-workspace 6; }
    Super+7 { focus-workspace 7; }
    Super+8 { focus-workspace 8; }
    Super+9 { focus-workspace 9; }
    Super+0 { focus-workspace 10; }

    Super+Shift+1 { move-column-to-workspace 1; }
    Super+Shift+2 { move-column-to-workspace 2; }
    Super+Shift+3 { move-column-to-workspace 3; }
    Super+Shift+4 { move-column-to-workspace 4; }
    Super+Shift+5 { move-column-to-workspace 5; }
    Super+Shift+6 { move-column-to-workspace 6; }
    Super+Shift+7 { move-column-to-workspace 7; }
    Super+Shift+8 { move-column-to-workspace 8; }
    Super+Shift+9 { move-column-to-workspace 9; }
    Super+Shift+0 { move-column-to-workspace 10; }

    // if the window is alone, they will consume it into the nearby column to the side
    // if the window is already in a column, they will expel it out
    Super+BracketLeft  { consume-or-expel-window-left; }
    Super+BracketRight { consume-or-expel-window-right; }

    // consume one window from the right to the bottom of the focused column
    Super+Comma  { consume-window-into-column; }
    // expel the bottom window from the focused column to the right
    Super+Period { expel-window-from-column; }

    // cycle through widths set in preset-column-widths
    Super+Space   { switch-preset-column-width; }
    Super+R       { switch-preset-column-width; }
    Super+Shift+R { switch-preset-column-width-back; }

    Super+Ctrl+M { expand-column-to-available-width; }
    Super+Ctrl+W { maximize-window-to-edges; }
    Super+Ctrl+F { fullscreen-window; }

    Super+Ctrl+C { center-column; }

    Super+Ctrl+Minus { set-column-width "-10%"; }
    Super+Ctrl+Equal { set-column-width "+10%"; }

    Super+Ctrl+Shift+Minus { set-window-height "-10%"; }
    Super+Ctrl+Shift+Equal { set-window-height "+10%"; }

    Super+Ctrl+V       { toggle-window-floating; }
    Super+Ctrl+Shift+V { switch-focus-between-floating-and-tiling; }

    Super+Ctrl+T { toggle-column-tabbed-display; }

    // turn off keyboard inhibiting a vm or other app has turned on
    Super+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }
}

//======================================================================
// End of File
//======================================================================
