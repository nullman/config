#===============================================================================
# .config/systemd/user/resume.service
#
# Configuration for systemd user resume service.
#
# Enable:   systemctl --user enable resume.service
# Start:    systemctl --user start resume.service
# Stop:     systemctl --user stop resume.service
# Disable:  systemctl --user disable resume.service
#
# Reference: https://wiki.archlinux.org/index.php/Systemd/User
#===============================================================================

[Unit]
Description=Resume Actions
Before=sleep.target
StopWhenUnneeded=yes

[Service]
Type=oneshot
RemainAfterExit=yes

# turn keyboard num-lock on
ExecStop=/bin/bash -c "while [ ! -S /tmp/.X11-unix/X0 ]; do sleep 1; done; numlockx"

# make capslock act like control; make both shift keys toggle capslock
ExecStop=/bin/bash -c "while [ ! -S /tmp/.X11-unix/X0 ]; do sleep 1; done; setxkbmap -option 'shift:both_capslock,caps:ctrl_modifier'"

# # disable insert key
# ExecStop=/bin/bash -c "while [ ! -S /tmp/.X11-unix/X0 ]; do sleep 1; done; xkbcomp ${DISPLAY} - | sed 's/ Insert / NoSymbol /' | xkbcomp - ${DISPLAY}"
ExecStop=/bin/bash -c "while [ ! -S /tmp/.X11-unix/X0 ]; do sleep 1; done; xmodmap -e 'keycode 118 ='"

# set mouse speed and keyboard rate
ExecStop=/bin/bash -c "while [ ! -S /tmp/.X11-unix/X0 ]; do sleep 1; done; xset -dpms s off b off m 2/1 4 r rate 500 35"

[Install]
WantedBy=sleep.target

#===============================================================================
# End of File
#===============================================================================
