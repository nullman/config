#===============================================================================
# .config/systemd/user/xscreensaver-watch.service
#
# Configuration for systemd user xscreensaver-watch service.
#
# Enable:   systemctl --user enable xscreensaver-watch.service
# Start:    systemctl --user start xscreensaver-watch.service
# Stop:     systemctl --user stop xscreensaver-watch.service
# Disable:  systemctl --user disable xscreensaver-watch.service
#
# Reference: https://wiki.archlinux.org/index.php/Systemd/User
#===============================================================================

[Unit]
Description=Watch xscreensaver for UNLOCK

[Service]
ExecStart=bash -c 'DISPLAY=:0 \
                   xscreensaver-command -watch | while read -r line ; do \
                       if echo "$line" | grep -q "^UNBLANK" ; then \
                           [ "$(uname -n)" == "mouse" ] || numlockx on ; \
                           setxkbmap -option "shift:both_capslock,caps:ctrl_modifier" ; \
                           xmodmap -e "keycode 118 =" ; \
                           xset -dpms s off b off m 2/1 4 r rate 500 35 ; \
                       fi ; \
                   done'

[Install]
WantedBy=default.target

